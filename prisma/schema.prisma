// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Handled by prisma.config.ts in Prisma 6
}

model Prompt {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SavedUrl {
  id        String   @id @default(uuid())
  title     String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id            String   @id @default(uuid())
  title         String?  // Auto-generated like "Scrape 2026-06-18 10:00"
  type          String   @default("SCRAPE_AND_ANALYZE") // SCRAPE, ANALYZE, SCRAPE_AND_ANALYZE
  url           String?  // Optional for ANALYZE type
  promptContent String?  // Optional for SCRAPE type
  apifyRunId    String?
  sourceJobIds  String[] // IDs of SCRAPE jobs used for this ANALYZE job
  status        String   @default("PENDING") // PENDING, SCRAPING, ANALYZING, COMPLETED, FAILED
  rawScrapeData String?  @db.Text // Store raw JSON from Apify
  resultReport  String?  @db.Text // Store Markdown from Gemini
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
